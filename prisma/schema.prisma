generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== USERS & AUTH ==========
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("vendedor") // admin, vendedor, tecnico
  avatar       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales        Sale[]
  serviceOrders ServiceOrder[]
  auditLogs    AuditLog[]
}

// ========== PRODUCTS ==========
model Product {
  id            String   @id @default(uuid())
  name          String
  category      String   // iphone, acessorio, peca
  brand         String   @default("Apple")
  model         String?
  color         String?
  storage       String?  // 64GB, 128GB, 256GB, etc
  sku           String?  @unique
  costPrice     Float    @default(0)
  salePrice     Float    @default(0)
  minStock      Int      @default(2)
  description   String?
  warranty      Int      @default(12) // months
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryItems InventoryItem[]
  saleItems      SaleItem[]
  serviceItems   ServiceItem[]
}

// ========== INVENTORY (IMEI CONTROL) ==========
model InventoryItem {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  imei        String?  @unique
  serialNumber String?
  status      String   @default("disponivel") // disponivel, vitrine, reservado, vendido, defeito, assistencia
  location    String   @default("estoque") // estoque, vitrine, deposito
  condition   String   @default("novo") // novo, seminovo, usado, recondicionado
  costPrice   Float    @default(0)
  notes       String?
  supplier    String?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleItem    SaleItem?
  movements   StockMovement[]
}

// ========== STOCK MOVEMENTS ==========
model StockMovement {
  id            String   @id @default(uuid())
  inventoryItemId String
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  type          String   // entrada, saida, transferencia, ajuste
  fromLocation  String?
  toLocation    String?
  reason        String?
  createdAt     DateTime @default(now())
}

// ========== CUSTOMERS (CRM) ==========
model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  cpf         String?  @unique
  address     String?
  city        String?
  state       String?
  zipCode     String?
  birthDate   DateTime?
  notes       String?
  score       Int      @default(50) // 0-100 AI score
  totalSpent  Float    @default(0)
  totalOrders Int      @default(0)
  lastPurchase DateTime?
  tags        String?  // comma-separated tags
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales        Sale[]
  serviceOrders ServiceOrder[]
}

// ========== SALES ==========
model Sale {
  number        Int      @id @default(autoincrement())
  id            String   @unique @default(uuid())
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  sellerId      String
  seller        User     @relation(fields: [sellerId], references: [id])
  status        String   @default("finalizada") // rascunho, finalizada, cancelada
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  costTotal     Float    @default(0)
  profit        Float    @default(0)
  profitMargin  Float    @default(0)
  paymentMethod String   @default("dinheiro") // dinheiro, pix, credito, debito, misto
  installments  Int      @default(1)
  cardFee       Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         SaleItem[]
  payments      Payment[]
}

model SaleItem {
  id            String   @id @default(uuid())
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  inventoryItemId String? @unique
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  quantity      Int      @default(1)
  unitPrice     Float
  costPrice     Float    @default(0)
  discount      Float    @default(0)
  total         Float
}

// ========== PAYMENTS ==========
model Payment {
  id          String   @id @default(uuid())
  saleId      String?
  sale        Sale?    @relation(fields: [saleId], references: [id])
  type        String   // receita, despesa
  method      String   // dinheiro, pix, credito, debito, boleto, transferencia
  amount      Float
  fee         Float    @default(0)
  netAmount   Float
  installments Int     @default(1)
  dueDate     DateTime?
  paidAt      DateTime?
  status      String   @default("pago") // pendente, pago, atrasado, cancelado
  description String?
  category    String?  // venda, servico, aluguel, salario, fornecedor, outros
  createdAt   DateTime @default(now())
}

// ========== SERVICE ORDERS (ASSISTÊNCIA TÉCNICA) ==========
model ServiceOrder {
  number        Int      @id @default(autoincrement())
  id            String   @unique @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  technicianId  String?
  technician    User?    @relation(fields: [technicianId], references: [id])
  deviceModel   String
  deviceImei    String?
  deviceColor   String?
  devicePassword String?
  issueDescription String
  diagnosis     String?
  solution      String?
  status        String   @default("recebido") // recebido, diagnosticando, aguardando_peca, em_reparo, pronto, entregue, cancelado
  priority      String   @default("normal") // baixa, normal, alta, urgente
  estimatedCost Float?
  finalCost     Float?
  estimatedDate DateTime?
  completedAt   DateTime?
  warrantyDays  Int      @default(90)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         ServiceItem[]
}

model ServiceItem {
  id              String   @id @default(uuid())
  serviceOrderId  String
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  description     String
  quantity        Int      @default(1)
  unitPrice       Float
  total           Float
}

// ========== FINANCIAL ==========
model Transaction {
  id          String   @id @default(uuid())
  type        String   // receita, despesa
  category    String   // venda, servico, aluguel, salario, fornecedor, imposto, outros
  description String
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  status      String   @default("pendente") // pendente, pago, atrasado, cancelado
  recurring   Boolean  @default(false)
  recurrenceType String? // mensal, semanal, anual
  costCenter  String?
  notes       String?
  createdAt   DateTime @default(now())
}

// ========== SUPPLIERS ==========
model Supplier {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  cnpj        String?
  address     String?
  category    String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== AUDIT LOG ==========
model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String   // create, update, delete, login, logout
  entity      String   // sale, product, customer, etc
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

// ========== SETTINGS ==========
model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
  type  String @default("string") // string, number, boolean, json
}
